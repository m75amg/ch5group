# ─── Site ────────────────────────────────────────────────────────────────────
# Production canonical URL — used by sitemap.xml, robots.txt, OG metadata,
# and JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://channel5korea.com

# ─── Database (PostgreSQL via Prisma) ────────────────────────────────────────
# Local dev: docker compose up -d  (uses docker-compose.yml)
# Production EC2: install postgresql-16, create role + db, point this at it.
DATABASE_URL=postgresql://ch5:CHANGE_ME@localhost:5432/ch5korea?schema=public

# ─── NextAuth (admin login) ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Production: https://ch5group.com (or whichever canonical domain)
NEXTAUTH_URL=http://localhost:3000

# ─── Analytics ───────────────────────────────────────────────────────────────
# Both are optional. Scripts are skipped when empty or when NODE_ENV !== "production".
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# ─── Contact form (Resend) ───────────────────────────────────────────────────
# Set all three before launch. Without them /api/contact returns ok with
# delivery: "stub" — useful for dev/preview, NOT for production.
RESEND_API_KEY=
# Must be on a verified Resend sending domain.
RESEND_FROM_EMAIL=Channel5 Korea <noreply@channel5korea.com>
# Operations inbox that receives notification emails.
OPERATIONS_INBOX_EMAIL=partnership@channel5korea.com

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────────────
# When unset the API route skips verification (dev/preview convenience).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
